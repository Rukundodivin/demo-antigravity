# Variables d'Environnement pour VibeAI Magazine

# Clé API YouTube Data v3 (Nécessaire pour la recherche de vidéos)
YOUTUBE_API_KEY=votre_cle_api_youtube_ici

# Clé API pour le modèle LLM (OpenAI ou Google Gemini)
LLM_API_KEY=votre_cle_api_ia_ici

# Note : Renommez ce fichier en `.env` avant d'exécuter le pipeline.
